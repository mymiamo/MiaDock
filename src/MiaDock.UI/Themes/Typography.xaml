<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="IslandTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{ThemeResource IslandTextPrimaryBrush}" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style x:Key="IslandBodyTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{ThemeResource IslandTextSecondaryBrush}" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style x:Key="IslandCaptionTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Variable Small" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{ThemeResource IslandTextSecondaryBrush}" />
  </Style>
</ResourceDictionary>
