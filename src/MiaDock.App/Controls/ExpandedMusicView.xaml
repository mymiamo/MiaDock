<UserControl
    x:Class="MiaDock.App.Controls.ExpandedMusicView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:MiaDock.App.Controls">

  <Grid Padding="{StaticResource IslandExpandedPadding}" ColumnSpacing="16" RowSpacing="12">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="112" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <controls:AlbumArtwork Grid.RowSpan="3" Width="112" Height="112" VerticalAlignment="Top" />

    <Grid Grid.Column="1" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Spacing="3">
        <TextBlock MaxLines="1" Style="{StaticResource IslandTitleTextStyle}" Text="{Binding Current.Track.Title}" />
        <TextBlock MaxLines="1" Style="{StaticResource IslandBodyTextStyle}" Text="{Binding Current.Track.Artist}" />
        <TextBlock MaxLines="1" Style="{StaticResource IslandCaptionTextStyle}" Text="{Binding Current.Track.AlbumTitle}" />
      </StackPanel>
      <controls:SourceAppBadge Grid.Column="1" VerticalAlignment="Top" />
    </Grid>

    <controls:MediaTimeline Grid.Row="1" Grid.Column="1" />

    <Grid Grid.Row="2" Grid.Column="1" ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <controls:MediaTransportControls />
      <controls:VolumeControl Grid.Column="2" VerticalAlignment="Center" />
    </Grid>
  </Grid>
</UserControl>
