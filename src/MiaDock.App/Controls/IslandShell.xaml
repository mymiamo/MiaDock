<UserControl
    x:Class="MiaDock.App.Controls.IslandShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid x:Name="LayoutRoot"
        Width="{ThemeResource IslandCollapsedWidth}"
        Height="{ThemeResource IslandCollapsedHeight}">
    <Border x:Name="Surface"
            Background="{ThemeResource IslandStyleSurfaceBrush}"
            BorderBrush="{ThemeResource IslandStrokeBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource IslandCornerRadius}">
      <Grid x:Name="ContentHost" />
    </Border>
  </Grid>
</UserControl>
