<UserControl
    x:Class="MiaDock.App.Controls.SourceAppBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Padding="8,4"
          Background="{ThemeResource IslandControlFillBrush}"
          CornerRadius="12">
    <StackPanel Orientation="Horizontal" Spacing="6">
      <Image Width="16"
             Height="16"
             Source="{Binding Current.Source.IconUri}"
             AutomationProperties.AccessibilityView="Raw" />
      <TextBlock MaxWidth="120"
                 Style="{StaticResource IslandCaptionTextStyle}"
                 Text="{Binding Current.Source.DisplayName}" />
    </StackPanel>
  </Border>
</UserControl>
