<UserControl
    x:Class="MiaDock.App.Controls.MediaTransportControls"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <StackPanel Orientation="Horizontal" Spacing="8">
    <Button Style="{StaticResource IslandIconButtonStyle}"
            Command="{Binding PreviousCommand}"
            ToolTipService.ToolTip="Previous track"
            AutomationProperties.Name="Previous track">
      <FontIcon Glyph="&#xE892;" FontSize="16" />
    </Button>
    <Button Style="{StaticResource IslandIconButtonStyle}"
            Command="{Binding PlayPauseCommand}"
            ToolTipService.ToolTip="Play or pause"
            AutomationProperties.Name="Play or pause">
      <FontIcon Glyph="{Binding PlaybackGlyph}" FontSize="17" />
    </Button>
    <Button Style="{StaticResource IslandIconButtonStyle}"
            Command="{Binding NextCommand}"
            ToolTipService.ToolTip="Next track"
            AutomationProperties.Name="Next track">
      <FontIcon Glyph="&#xE893;" FontSize="16" />
    </Button>
  </StackPanel>
</UserControl>
