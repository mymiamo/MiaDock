<UserControl
    x:Class="MiaDock.App.Controls.VolumeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <StackPanel Orientation="Horizontal" Spacing="8">
    <FontIcon Glyph="&#xE767;"
              FontSize="15"
              Foreground="{ThemeResource IslandTextSecondaryBrush}"
              AutomationProperties.AccessibilityView="Raw" />
    <Slider Width="90"
            Minimum="0"
            Maximum="100"
            Value="{Binding VolumePercent, Mode=TwoWay}"
            IsEnabled="{Binding Current.Capabilities.CanChangeVolume}"
            AutomationProperties.Name="Volume" />
  </StackPanel>
</UserControl>
